# All keys are OPTIONAL — the app works without any of them.
# Leave blank or remove lines you don't need.

# Discogs (optional) — enables collection-based recommendations
# Get your token at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=
DISCOGS_USERNAME=

# Claude AI (optional) — cloud-based AI recommendations
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Ollama (optional) — free local AI (default: http://localhost:11434)
# Install from https://ollama.com, then: ollama pull llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Session secret (optional) — auto-generated if not set
# Sessions won't survive app restarts without this
# SECRET_KEY=
